{
    "name": "WatchTower Dev Container",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
      "ghcr.io/devcontainers/features/python:1": {
        "version": "3.11",
        "installJupyterlab": false
      },
      "ghcr.io/devcontainers/features/node:1": {
        "version": "lts"
      },
      "ghcr.io/devcontainers/features/azure-cli:1": {},
      "ghcr.io/devcontainers/features/docker-in-docker:2": {},
      "ghcr.io/azure/azure-dev/azd:latest": {}
    },
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-python.python",
          "ms-python.vscode-pylance",
          "charliermarsh.ruff",
          "ms-azuretools.vscode-azurefunctions",
          "ms-azuretools.vscode-bicep",
          "ms-azuretools.vscode-docker",
          "ms-azuretools.vscode-azureresourcegroups",
          "esbenp.prettier-vscode"
        ],
        "settings": {
          "python.analysis.autoImportCompletions": true,
          "python.terminal.activateEnvironment": false
        }
      }
    },
    "remoteEnv": {
      "POETRY_VIRTUALENVS_IN_PROJECT": "true",
      "POETRY_VIRTUALENVS_CREATE": "true"
    },
    "postCreateCommand": "bash -lc 'set -e; sudo apt-get update && sudo apt-get install -y jq git-lfs && az bicep install && npm i -g azure-functions-core-tools@4 --unsafe-perm true && pip install --upgrade pip && pip install poetry && poetry config virtualenvs.in-project true'",
    "forwardPorts": [7071, 3000],
    "portsAttributes": {
      "7071": { "label": "Azure Functions" },
      "3000": { "label": "Web UI" }
    }
}
